---
import '../styles/global.css'
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';

interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <footer>
      <p>© 2026 Your Name</p>
    </footer>
  </body>
</html>